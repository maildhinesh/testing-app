# --- Environment ---
# "development" (default) or "production". In production the app refuses to boot
# with the default JWT_SECRET / ADMIN_PASSWORD below.
ENVIRONMENT=development

# --- Database ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/tamil_test

# --- Security ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=480
# Token lifetimes (minutes)
EMAIL_VERIFY_EXPIRE_MINUTES=1440
MAGIC_LINK_EXPIRE_MINUTES=2880

# --- Bootstrap admin (created on first startup if not present) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345
ADMIN_NAME=Test Admin

# --- SMTP / Email ---
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@example.com
SMTP_USE_TLS=true

# --- App URLs (used to build links in emails) ---
FRONTEND_BASE_URL=http://localhost:5173
BACKEND_BASE_URL=http://localhost:8000

# --- Test rules ---
TEST_TOTAL_MINUTES=75
