# Frontend build-time configuration (Vite).
# Copy to .env.production (or set in your host's build env) when deploying.

# Absolute URL of the backend API, including the /api suffix.
# Only needed for cross-origin static hosting (Option B in the README).
# If you use a host rewrite that forwards /api -> backend (Option A), leave this unset.
VITE_API_BASE_URL=https://your-backend.onrender.com/api
